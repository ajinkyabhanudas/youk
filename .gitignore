# Python
__pycache__/
*.py[cod]
*.pyo
.env
*.egg-info/
dist/
/build/
.venv/
venv/
.coverage
.coverage.*
coverage.json
coverage.xml
htmlcov/

# Docker
.dockerignore

# Runtime state (local only, not committed — state/.gitkeep IS committed for fresh clones)
state/*
!state/.gitkeep

# Generated dashboard reports (local only — regenerate with make report)
reports/

# Per-project session context (personal, local only — not shared across installs)
knowledge/projects/

# Instance-local knowledge — personal intelligence, never universally applicable
# Capabilities (skills, server code) belong in the repo; accumulated knowledge does not
knowledge/proposals/
knowledge/global/
knowledge/domain/*
!knowledge/domain/.gitkeep
knowledge/user-profile.md

# Accumulated /learn domain knowledge — grows per-user, never shared across installs
skills/learn/knowledge/

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp
*.swo

# Secrets
*.env
.env.*
*secret*
*credential*
*api_key*
